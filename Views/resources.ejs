<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>The Academic Atlas</title>

  <link rel="stylesheet" href="/css/resources.css">
</head>

<body>

  <div class="book-cover">
    <div class="huge-book">

      <div class="book-half left">
        <h1 class="library-title">The Library</h1>

        <p class="library-quote">
          "The more that you read, the more things you will know."
        </p>

        <hr class="library-line">

        <h3 class="section-title">📌 Quick Navigation</h3>

        <p class="library-text">
          Welcome to the ultimate resource hub. Here you can find all your study materials,
          lecture summaries, and helpful links organized by major.
        </p>
      </div>

      <div class="book-half right">
        <div class="close-btn" onclick="window.location.href='/cylinder#cylinder'">✖</div>

        <div class="flip-sheet">
          <div class="page-face front"></div>
          <div class="page-face back"></div>
        </div>

        <div class="main-content-container">

          <% if (!categories || categories.length === 0) { %>

            <div class="empty-resource-box">
              <h2>No resources yet</h2>
              <p>Resources will appear here after they are added to MongoDB.</p>
            </div>

          <% } else { %>

            <% categories.forEach(function(category, index) { %>

              <%
                const playlistResources = (category.resources || []).filter(function(resource) {
                  return resource.type === "playlist";
                });

                const bookResources = (category.resources || []).filter(function(resource) {
                  return resource.type === "book" || resource.type === "pdf" || resource.type === "website" || resource.type === "other";
                });
              %>

              <div 
                id="category-<%= category._id %>" 
                class="content-set <%= index === 0 ? 'active' : '' %>"
              >

                <h2 
                  class="subject-title" 
                  style="color: <%= category.color || '#0077b6' %>;"
                >
                  <%= category.name %>
                </h2>

                <h3 class="section-title">📺 YouTube Playlists</h3>

                <div class="link-grid">
                  <% if (playlistResources.length === 0) { %>

                    <p class="empty-resource-text">
                      No playlists added yet.
                    </p>

                  <% } else { %>

                    <% playlistResources.forEach(function(resource) { %>
                      <a 
                        href="<%= resource.url %>" 
                        target="_blank" 
                        class="resource-card" 
                        style="--hover-color: var(--yt-red);"
                      >
                        <span><%= resource.title %></span>
                        <span class="icon-label">PLAYLIST ➔</span>
                      </a>
                    <% }) %>

                  <% } %>
                </div>

                <h3 class="section-title">📚 Books & PDFs</h3>

                <div class="link-grid">
                  <% if (bookResources.length === 0) { %>

                    <p class="empty-resource-text">
                      No books, PDFs, or websites added yet.
                    </p>

                  <% } else { %>

                    <% bookResources.forEach(function(resource) { %>

                      <%
                        let label = "LINK ➔";

                        if (resource.type === "pdf") {
                          label = "PDF ⬇";
                        } else if (resource.type === "book") {
                          label = "BOOK ➔";
                        } else if (resource.type === "website") {
                          label = "WEBSITE ➔";
                        }
                      %>

                      <a 
                        href="<%= resource.url %>" 
                        target="_blank" 
                        class="resource-card" 
                        style="--hover-color: <%= category.color || '#0077b6' %>;"
                      >
                        <span><%= resource.title %></span>
                        <span class="icon-label"><%= label %></span>
                      </a>

                    <% }) %>

                  <% } %>
                </div>

              </div>

            <% }) %>

          <% } %>

        </div>

        <% if (categories && categories.length > 0) { %>
          <div class="tabs-container">
            <% categories.forEach(function(category, index) { %>
              <div 
                class="tab <%= index === 0 ? 'active' : '' %>"
                style="background: <%= category.color || '#0077b6' %>;"
                onclick="switchTab('category-<%= category._id %>', this)"
              >
                <%= category.shortName %>
              </div>
            <% }) %>
          </div>
        <% } %>

      </div>

    </div>
  </div>

  <script src="/javaScript/resources.js"></script>

</body>
</html>