<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Study Buddy Events</title>

  <link rel="stylesheet" href="/css/events.css">
</head>

<body>
  <div class="close-btn" onclick="window.location.href='/cylinder#cylinder'">✖</div>

  <div class="dashboard-wrapper">

    <!-- HERO SECTION -->
    <div class="hero-command-center reveal-item fx-zoom-in">
      <span class="hero-badge">Entertainment + Sports Tournaments</span>

      <h1 class="hero-main-title">
        Study Buddy Events
      </h1>

      <p class="hero-description">
        Events, tournaments, and concerts now live inside the Study Buddy hub.
      </p>
    </div>


    <!-- SPORTS SECTION FIRST -->
    <section class="events-section sports-section">

      <div class="header-title-area reveal-item fx-slide-right delay-100">
        <span class="discover-badge">Sports</span>
        <h1 class="main-dashboard-title">Sports & Tournaments</h1>
      </div>

      <div class="grid-layout">

        <% if (!sportsEvents || sportsEvents.length === 0) { %>
          <p style="color: white; font-size: 18px;">No sports events added yet.</p>
        <% } %>

        <% if (sportsEvents && sportsEvents.length > 0) { %>
          <% sportsEvents.forEach(function(event, index) { %>

            <div 
              class="custom-dashboard-card <%= index === 0 ? 'card-large-item' : 'card-regular-item' %> reveal-item <%= index % 3 === 0 ? 'fx-slide-right' : index % 3 === 1 ? 'fx-slide-up-scale' : 'fx-slide-left' %> delay-100" 
              style="background-image: url('<%= event.imagePath %>');"
            >

              <div class="card-top-badges">
                <span class="inner-pill-badge"><%= event.category %></span>
                <span class="inner-pill-badge admin-live">Admin Live</span>
              </div>

              <div class="card-dark-gradient-layer"></div>

              <div class="card-inner-content">
                <h2 class="card-main-heading"><%= event.title %></h2>

                <p class="card-brief-desc">
                  <%= event.description %>
                </p>

                <% if (event.buttonType === "register") { %>
                  <button 
                    class="action-gradient-btn" 
                    onclick='openRegistration(event, <%- JSON.stringify(event.title) %>, <%= event.maxPlayers || 10 %>)'
                  >
                    Register
                  </button>
                <% } else { %>
                  <button 
                    class="action-gradient-btn" 
                    onclick='window.open(<%- JSON.stringify(event.detailsLink || "#") %>, "_blank")'
                  >
                    View Details
                  </button>
                <% } %>
              </div>

            </div>

          <% }) %>
        <% } %>

      </div>
    </section>


    <br> <br> <br>

    <!-- ENTERTAINMENT SECTION SECOND -->
    <section class="events-section entertainment-section">

      <div class="header-title-area reveal-item fx-slide-right delay-100">
        <span class="discover-badge">Entertainment</span>
        <h1 class="main-dashboard-title">Entertainment Events</h1>
      </div>

      <div class="grid-layout">

        <% if (!entertainmentEvents || entertainmentEvents.length === 0) { %>
          <p style="color: white; font-size: 18px;">No entertainment events added yet.</p>
        <% } %>

        <% if (entertainmentEvents && entertainmentEvents.length > 0) { %>
          <% entertainmentEvents.forEach(function(event, index) { %>

            <div 
              class="custom-dashboard-card card-regular-item reveal-item <%= index % 3 === 0 ? 'fx-slide-right' : index % 3 === 1 ? 'fx-slide-up-scale' : 'fx-slide-left' %> delay-100" 
              style="background-image: url('<%= event.imagePath %>');"
            >

              <div class="card-top-badges">
                <span class="inner-pill-badge"><%= event.category %></span>
                <span class="inner-pill-badge admin-live">Admin Live</span>
              </div>

              <div class="card-dark-gradient-layer"></div>

              <div class="card-inner-content">
                <h2 class="card-main-heading"><%= event.title %></h2>

                <p class="card-brief-desc">
                  <%= event.description %>
                </p>

                <% if (event.buttonType === "register") { %>
                  <button 
                    class="action-gradient-btn" 
                    onclick='openRegistration(event, <%- JSON.stringify(event.title) %>, <%= event.maxPlayers || 10 %>)'
                  >
                    Register
                  </button>
                <% } else { %>
                  <button 
                    class="action-gradient-btn" 
                    onclick='window.open(<%- JSON.stringify(event.detailsLink || "#") %>, "_blank")'
                  >
                    View Details
                  </button>
                <% } %>
              </div>

            </div>

          <% }) %>
        <% } %>

      </div>
    </section>

  </div>


  <!-- REGISTRATION MODAL -->
  <div id="registration-modal" class="hidden modal-overlay">
    <div class="modal-content">

      <div class="modal-title-row">
        <h2 id="modal-tournament-name">Tournament Name</h2>
        <button class="close-modal-x" onclick="closeRegistration()">&times;</button>
      </div>

      <form id="team-form" onsubmit="submitTeam(event)">

        <div class="form-group">
          <label>Team Name *</label>
          <input type="text" id="team-name" required placeholder="Enter team name">
        </div>

        <div id="players-container"></div>

        <button type="button" class="add-player-btn" onclick="addPlayer()">
          + Add Another Player
        </button>

        <button type="submit" class="submit-btn">
          Complete Registration
        </button>

      </form>

    </div>
  </div>


  <!-- AUTH MODAL -->
  <div id="auth-modal" class="hidden modal-overlay">
    <div class="modal-content auth-content">

      <h2>Join the Game!</h2>

      <p>You need to have an account to register in tournaments.</p>

      <div class="auth-buttons">
        <button class="submit-btn" onclick="window.location.href='/login'">
          Login
        </button>

        <button class="add-player-btn signup-auth-btn" onclick="window.location.href='/signup'">
          Sign Up
        </button>

        <button class="close-modal-x maybe-later-btn" onclick="closeAuthModal()">
          Maybe Later
        </button>
      </div>

    </div>
  </div>


  <script>
  window.EVENTS_PAGE_DATA = {
    isLoggedIn: <%= user ? "true" : "false" %>
  };
</script>

  <script src="/javaScript/events.js"></script>

</body>
</html>