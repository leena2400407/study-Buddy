<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>
    <%= typeof pageTitle !== "undefined" ? pageTitle : "Study Buddy AI" %>
  </title>

  <link rel="stylesheet" href="/css/ai.css" />
</head>

<body>
  <div class="background">
    <div class="bg-glow glow-one"></div>
    <div class="bg-glow glow-two"></div>
    <div class="bg-grid"></div>
  </div>

  <div class="close-btn" onclick="window.location.href='/cylinder#cylinder'">✖</div>

  <main class="ai-page">
    <section class="top-card">
      <div class="brand">
        <div class="brand-logo">AI</div>

        <div>
          <p class="brand-small">Study Buddy</p>
          <h1>AI Assistant</h1>
        </div>
      </div>

      <p class="top-description">
        Ask anything. Get explanations, summaries, code help, study plans, project ideas,
        exam tips, and quick answers.
      </p>

      <div class="status-pill">
        <span></span>
        Gemini connected
      </div>
    </section>

    <section class="chat-card">
      <header class="chat-header">
        <div class="assistant-meta">
          <div class="assistant-avatar">✦</div>

          <div>
            <h2>Study Buddy AI</h2>
            <p id="chatStatus">Online • Ask me anything</p>
          </div>
        </div>

        <button id="clearBtn" class="clear-btn" type="button">
          Clear chat
        </button>
      </header>

      <section class="start-screen" id="startScreen">
        <div class="start-icon">🤖</div>

        <h3>Ready when you are</h3>

        <p>
          Start a clean AI chat. The assistant will answer openly like Gemini,
          not with preset topic replies.
        </p>

        <button class="start-btn" id="startBtn" type="button">
          Start chatting
        </button>
      </section>

      <section class="chat-ui hidden" id="chatUi">
        <div class="chat-box" id="chatBox"></div>

        <form class="chat-form" id="chatForm">
          <div class="input-box">
            <textarea
              id="messageInput"
              placeholder="Type your question..."
              rows="1"
              autocomplete="off"
              required
            ></textarea>

            <div class="input-info">
              <span id="charCount">0 characters</span>
              <span>Enter to send • Shift + Enter for new line</span>
            </div>
          </div>

          <button id="sendBtn" type="submit">
            <span>Send</span>
            <span>➜</span>
          </button>
        </form>
      </section>
    </section>
  </main>

  <script src="/javaScript/ai.js"></script>
</body>
</html>